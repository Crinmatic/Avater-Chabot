[Unit]
Description=AI Avatar Chatbot Backend Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Avater-Chabot
Environment="PATH=/home/ubuntu/Avater-Chabot/venv/bin"
ExecStart=/home/ubuntu/Avater-Chabot/venv/bin/python /home/ubuntu/Avater-Chabot/backend/server.py
Restart=always
RestartSec=10
StandardOutput=append:/home/ubuntu/Avater-Chabot/logs/backend.log
StandardError=append:/home/ubuntu/Avater-Chabot/logs/backend-error.log

# Resource limits (optional, adjust as needed)
# LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
